    "@mastra/ai-sdk": "^1.1.2",
    "@mastra/core": "^1.10.0",
    "@tavily/core": "^0.7.2",
    "ai": "^6.0.116",
    "mastra": "^1.3.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
